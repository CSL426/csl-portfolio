# Repo-root .env — both apps/api (FastAPI) and docker-compose read from here.
# Copy to .env and fill in. Per-app override: apps/api/.env wins over root .env.

# ──────────────────────────── Public surface ─────────────────────────────────
# THE ONLY port published to the host. API + nginx live on docker's internal
# network; everything reachable from outside comes through this one port.
PUBLIC_PORT=8787

# ──────────────────────────── Backend (apps/api) ─────────────────────────────

APP_ENV=dev
LOG_LEVEL=INFO

# CORS (JSON array). If unset, defaults to http://localhost:5173 pair.
# CORS_ORIGINS='["http://localhost:5173","https://your.domain"]'

# --- LINE Messaging API ---
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Agents ---
# echo | adk
DEFAULT_AGENT=adk

# --- Google ADK / Gemini ---
# Google AI Studio key — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
ADK_MODEL=gemini-3.1-flash-lite
ADK_APP_NAME=csl-portfolio
