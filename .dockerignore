# Repo-root .dockerignore — applies to any build context rooted here.
# Each app's own .dockerignore narrows further.

# VCS / editor
.git/
.github/
.gitignore
.vscode/
.idea/
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Build / cache
node_modules/
**/node_modules/
**/dist/
**/.vite/
**/.cache/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/__pycache__/
**/.venv/
**/venv/

# Logs / coverage
*.log
coverage/

# Docs / archive (not needed inside images)
docs/
archive/
reference/
assets/
README.md
AGENTS.md
CLAUDE.md
GEMINI.md
